#!/bin/bash
set -euo pipefail

SKILLS_DIR="$HOME/.agents/skills"
REPO_ROOT="$(git rev-parse --show-toplevel)"

# ============================================
# Phase 1 — 清理编译/使用产物（不限 changed_skills）
# ============================================

CLEAN_PATTERNS=(
    -name "__pycache__" -o
    -name "node_modules" -o
    -name ".mypy_cache" -o
    -name ".ruff_cache" -o
    -name ".pytest_cache" -o
    -name ".DS_Store" -o
    -name "*.pyc"
)

# 根级别
rm -rf "$REPO_ROOT/.playwright-mcp"
find "$REPO_ROOT" -maxdepth 1 \( "${CLEAN_PATTERNS[@]}" \) -exec rm -rf {} + 2>/dev/null || true

# 所有 skill 目录
for dir in "$REPO_ROOT"/*/; do
    [ ! -f "$dir/SKILL.md" ] && continue
    find "$dir" \( "${CLEAN_PATTERNS[@]}" \) -exec rm -rf {} + 2>/dev/null || true
done

# ============================================
# Phase 2 — 同步 changed_skills
# ============================================

changed_skills=()

while IFS= read -r file; do
    [ -z "$file" ] && continue
    dir="${file%%/*}"
    if [ -f "$REPO_ROOT/$dir/SKILL.md" ]; then
        changed_skills+=("$dir")
    fi
done < <(git diff --cached --name-only)

# deduplicate
if [ ${#changed_skills[@]} -gt 0 ]; then
    changed_skills=($(printf '%s\n' "${changed_skills[@]}" | sort -u))
fi

if [ ${#changed_skills[@]} -eq 0 ]; then
    echo "[skill-sync] No skill changes, skipping."
    exit 0
fi

echo "[skill-sync] Syncing ${#changed_skills[@]} skill(s) to $SKILLS_DIR: ${changed_skills[*]}"
mkdir -p "$SKILLS_DIR"
for skill in "${changed_skills[@]}"; do
    rm -rf "$SKILLS_DIR/$skill"
    cp -R "$REPO_ROOT/$skill" "$SKILLS_DIR/$skill"
    echo "  → $SKILLS_DIR/$skill"
done
echo "[skill-sync] Done."
exit 0
